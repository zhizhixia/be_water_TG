# Telegram API credentials (get from https://my.telegram.org)
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# Phone number (with country code)
PHONE=+8613800138000

# Target groups (TARGET_GROUPS preferred; comma-separated)
# TARGET_GROUPS=https://t.me/group1, https://t.me/group2
TARGET_GROUP=https://t.me/your_group

# Send interval (seconds)
MIN_INTERVAL=20
MAX_INTERVAL=30

# Proxy config (optional, skip for direct connection)
# PROXY_HOST=127.0.0.1
# PROXY_PORT=7890
# PROXY_TYPE=http

# Message file mapping (optional, format: username:path, ...)
# MESSAGE_FILES=group_username:messages.txt

# AI 聊天模式配置（DeepSeek API）
# AI_ENABLED=false
# AI_API_KEY=sk-your-deepseek-api-key
# AI_BASE_URL=https://api.deepseek.com/v1
# AI_MODEL=deepseek-chat
# AI_PROMPT=你是一个普通群聊参与者，请根据对话上下文自然地回复消息
# AI_CONTEXT_COUNT=5

# 定时运行窗口（可选）
# SCHEDULE_ENABLED=false
# SCHEDULE_MORNING_START=08:00
# SCHEDULE_MORNING_END=11:00
# SCHEDULE_AFTERNOON_START=14:00
# SCHEDULE_AFTERNOON_END=18:00

# 反检测增强（可选，随机间隔+emoji）
# ANTI_DETECT=false

# 反检测增强（真人模拟参数）
# TYPING_DELAY_MIN=3
# TYPING_DELAY_MAX=8
# THINKING_DELAY_MIN=5
# THINKING_DELAY_MAX=25
# SKIP_ROUND_PCT=10
